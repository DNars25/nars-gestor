# ================================================
# NARS IPTV MANAGER - Variáveis de Ambiente
# ================================================
# IMPORTANTE: Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env no git!

# ================================================
# BANCOS DE DADOS
# ================================================

# Banco próprio do painel (criar antes: CREATE DATABASE nars_painel; GRANT ALL ON nars_painel.* TO 'nars_painel'@'127.0.0.1' IDENTIFIED BY 'sua_senha';)
DATABASE_URL="mysql://nars_painel:SUA_SENHA_AQUI@127.0.0.1:3306/nars_painel"

# Banco XUI (read-only - já configurado no servidor)
# Criar usuário: CREATE USER 'nars_reader'@'127.0.0.1' IDENTIFIED BY 'sua_senha'; GRANT SELECT ON xui.* TO 'nars_reader'@'127.0.0.1'; FLUSH PRIVILEGES;
XUI_DB_URL="mysql://nars_reader:SUA_SENHA_READER@127.0.0.1:3306/xui"

# Banco XUI (escrita - para criar/editar/deletar/bloquear clientes)
# Criar usuário: CREATE USER 'nars_writer'@'127.0.0.1' IDENTIFIED BY 'sua_senha'; GRANT SELECT,INSERT,UPDATE,DELETE ON xui.* TO 'nars_writer'@'127.0.0.1'; FLUSH PRIVILEGES;
XUI_DB_WRITE_URL="mysql://nars_writer:SUA_SENHA_WRITER@127.0.0.1:3306/xui"

# Servidor XUI — host e porta separados (usados nos links M3U e Xtream no frontend)
NEXT_PUBLIC_XUI_HOST="http://149.248.46.167"
NEXT_PUBLIC_XUI_PORT="80"

# ================================================
# REDIS
# ================================================
REDIS_URL="redis://localhost:6379"

# ================================================
# AUTENTICAÇÃO JWT
# ================================================
# Gerar com: openssl rand -base64 32
NEXTAUTH_SECRET="GERAR_COM_openssl_rand_-base64_32"
NEXTAUTH_URL="https://painel.seudominio.com"
JWT_SECRET="GERAR_COM_openssl_rand_-base64_32"
JWT_REFRESH_SECRET="GERAR_COM_openssl_rand_-base64_32"

# ================================================
# CONFIGURAÇÃO
# ================================================
AUTH_TRUST_HOST="true"
NODE_ENV="production"
# "false" = HTTP puro (VPS sem SSL). "true" = SOMENTE se tiver HTTPS (Nginx + Certbot)
COOKIE_SECURE="false"

# ================================================
# GATEWAY PIX (opcional - configurar na Fase 2)
# ================================================
# EFI_CLIENT_ID=""
# EFI_CLIENT_SECRET=""
# EFI_CERTIFICATE_PATH=""

# ================================================
# MONITORAMENTO (opcional)
# ================================================
# SENTRY_DSN=""
